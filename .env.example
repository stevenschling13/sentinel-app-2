# ============================================
# Sentinel Trading Platform 2.0 — Environment
# ============================================
# Copy to .env and fill in your credentials.
# See CLAUDE.md for production values and deployment targets.

# ── Supabase ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Market Data (Polygon.io) ─────────────────
POLYGON_API_KEY=your-polygon-key

# ── Broker (Alpaca) ──────────────────────────
ALPACA_API_KEY=your-alpaca-key
ALPACA_SECRET_KEY=your-alpaca-secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
BROKER_MODE=paper

# ── AI Agents (Anthropic) ────────────────────
ANTHROPIC_API_KEY=your-anthropic-key

# ── Engine Service ───────────────────────────
# Local dev: http://localhost:8000
# Production: https://engine-production-8052.up.railway.app
ENGINE_URL=http://localhost:8000
ENGINE_API_KEY=sentinel-dev-key
# Comma-separated list of allowed CORS origins.
# Production should include: https://sentinel-app-2.vercel.app
# Vercel preview URLs (*.vercel.app) are auto-allowed by the engine.
CORS_ORIGINS=http://localhost:3000

# ── Agents Service ───────────────────────────
# Local dev: http://localhost:3001
# Production: https://agents-production-633a.up.railway.app
AGENTS_URL=http://localhost:3001
AGENTS_API_KEY=sentinel-dev-key
AGENTS_PORT=3001
# Comma-separated list of allowed frontend origins for agents CORS.
# Vercel preview URLs (*.vercel.app) are auto-allowed by agents.
WEB_URL=http://localhost:3000

# --- Orchestrator ---
AUTO_CYCLE=false
AUTO_EXECUTE=false
TRADING_MODE=paper
MAX_ORDER_VALUE=5000

# --- Upstash Redis Event Bus ---
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# --- External Data ---
FINNHUB_API_KEY=your-finnhub-key

# --- Notifications ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook

# ── Vercel-only vars (set in Vercel dashboard) ──
# AGENTS_API_KEY=<must match ENGINE_API_KEY sent to agents>
# ENGINE_API_KEY=<must match engine service's ENGINE_API_KEY>

# ── Deployment Notes ─────────────────────────
# 1. Vercel env vars are scoped per environment (Development/Preview/Production).
#    Changes only apply to NEW deployments — redeploy after updating.
# 2. Railway vars auto-trigger redeployment on change.
# 3. Never commit real keys to this file — use .env.local locally.
